{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://uniservice.onrender.com/api/$1"
    },
    {
      "source": "/imagenes-servicios/(.*)",
      "destination": "https://uniservice.onrender.com/imagenes-servicios/$1"
    },
    {
      "source": "/chathub/(.*)",
      "destination": "https://uniservice.onrender.com/chathub/$1"
    },
    {
      "source": "/chathub",
      "destination": "https://uniservice.onrender.com/chathub"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/og-image.png",
      "destination": "/og-image.png"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
