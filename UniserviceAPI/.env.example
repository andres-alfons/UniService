# ============================================
# VARIABLES DE ENTORNO - UniService API
# ============================================
# Copiar este archivo a .env y llenar los valores
# NUNCA commitear el archivo .env real
# ============================================

# Base de datos (Supabase PostgreSQL)
ConnectionStrings__DefaultConnection=Host=aws-1-sa-east-1.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.TU_PROYECTO;Password=TU_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# Supabase Storage
Supabase__Url=https://TU_PROYECTO.supabase.co
Supabase__ServiceKey=TU_SERVICE_KEY

# JWT Authentication
Jwt__Key=UNA_CLAVE_MUY_LARGA_Y_SEGURA_DE_AL_MENOS_64_CARACTERES

# Google OAuth
Google__ClientId=TU_GOOGLE_CLIENT_ID

# Brevo (Email API)
Brevo__ApiKey=TU_API_KEY_DE_BREVO
Brevo__FromEmail=andreselcrack1022@gmail.com
Brevo__FromName=UniService
