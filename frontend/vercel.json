{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://uniservice.onrender.com/api/$1"
    },
    {
      "source": "/imagenes-servicios/(.*)",
      "destination": "https://uniservice.onrender.com/imagenes-servicios/$1"
    },
    {
      "source": "/chathub/(.*)",
      "destination": "https://uniservice.onrender.com/chathub/$1"
    },
    {
      "source": "/chathub",
      "destination": "https://uniservice.onrender.com/chathub"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/og-image.png",
      "destination": "/og-image.png"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
