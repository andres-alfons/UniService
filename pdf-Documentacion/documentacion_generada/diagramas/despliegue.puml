@startuml
skinparam backgroundColor #FEFEFE

title Diagrama de Despliegue UML - UniService

skinparam node {
  BackgroundColor White
  BorderColor Black
}

node "Cliente / Usuario" as Cliente {
    artifact "Navegador Web" as Browser
}

node "Frontend Hosting\n(Vercel)" as FrontendHost {
    artifact "Aplicación React\n(Vite Build)" as ReactBuild
}

node "Servidor de API\n(Render)" as BackendHost {
    node "Contenedor .NET 8" as DockerAPI {
        artifact "API ASP.NET Core" as API
        artifact "Hub de Chat\n(SignalR)" as Hub
    }
}

node "Base de Datos y Storage\n(Supabase)" as DataLayer {
    database "PostgreSQL" as Postgres
    storage "Storage Bucket\n(Imágenes)" as Storage
}

node "Servicios Externos" as External {
    artifact "Google OAuth 2.0" as Google
    artifact "Gmail SMTP" as SMTP
}

Cliente --> FrontendHost : HTTPS
FrontendHost --> BackendHost : REST + WebSocket
BackendHost --> DataLayer : Conexión segura
BackendHost --> External : Autenticación + Email

@enduml
