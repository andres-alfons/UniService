@startuml
skinparam backgroundColor #FEFEFE

title Diagrama de Secuencia - Autenticación de Usuario

actor "Usuario" as User
participant "Navegador\n(React)" as Browser
participant "API\n(.NET)" as API
participant "Servicio de\nEncriptación" as BCrypt
participant "Servicio de\nTokens" as JWT
participant "Base de Datos" as DB

User -> Browser : Ingresa correo y contraseña
Browser -> API : Solicita autenticación

activate API
API -> DB : Consulta credenciales del usuario
activate DB
DB --> API : Retorna datos del usuario
 deactivate DB

API -> BCrypt : Verifica contraseña ingresada
activate BCrypt
BCrypt --> API : Contraseña válida
 deactivate BCrypt

alt Credenciales válidas
    API -> JWT : Genera token de sesión
    activate JWT
    JWT --> API : Token generado (expira en 24h)
    deactivate JWT

    API --> Browser : Confirma autenticación
    Browser -> Browser : Almacena token localmente
    Browser --> User : Redirige al inicio de la plataforma
else Credenciales inválidas
    API --> Browser : Indica error de autenticación
    Browser --> User : Muestra mensaje de error
end

deactivate API

@enduml
