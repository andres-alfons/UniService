@startuml
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam wrapWidth 200
skinparam usecase {
  BackgroundColor<<system>> LightYellow
  BorderColor<<system>> DarkOrange
}

title Diagrama de Casos de Uso - UniService

left to right direction

actor "Usuario" as Usuario
actor "Administrador" as Admin
actor "Sistema" as Sistema

rectangle "Plataforma UniService" {
    usecase "Registrar\nCuenta" as UC01
    usecase "Iniciar\nSesión" as UC02
    usecase "Gestionar\nPerfil" as UC03
    usecase "Publicar\nServicio" as UC04
    usecase "Buscar\nServicios" as UC05
    usecase "Ver Detalle\nde Servicio" as UC06
    usecase "Enviar\nSolicitud" as UC07
    usecase "Responder\nSolicitud" as UC08
    usecase "Comunicar\nvía Chat" as UC09
    usecase "Calificar\nServicio" as UC10
    usecase "Reportar\nContenido" as UC11
    usecase "Aprobar\nServicio" as UC12
    usecase "Gestionar\nReportes" as UC13
    usecase "Moderar\nUsuario" as UC14
    usecase "Enviar notificación\npor email" as UCNotif <<system>>
    usecase "Crear chat\nautomático" as UCChatAuto <<system>>

    UC07 ..> UCChatAuto : <<include>>
    UC07 ..> UCNotif : <<include>>
    UC08 ..> UCNotif : <<include>>
}

Usuario --> UC01
Usuario --> UC02
Usuario --> UC03
Usuario --> UC04
Usuario --> UC05
Usuario --> UC06
Usuario --> UC07
Usuario --> UC08
Usuario --> UC09
Usuario --> UC10
Usuario --> UC11

Admin --> UC12
Admin --> UC13
Admin --> UC14

Sistema --> UCNotif
Sistema --> UCChatAuto

@enduml
